# Copy to .env.local and fill in. Also set these in Vercel's env vars.

# Gmail account that SENDS the contact-form emails
GMAIL_USER=your-gmail@gmail.com

# Gmail App Password (16 chars) — NOT your normal password.
# Create at https://myaccount.google.com/apppasswords (needs 2-Step Verification on)
GMAIL_APP_PASSWORD=

# Who RECEIVES enquiries (comma-separated). Defaults to GMAIL_USER if unset.
CONTACT_TO=founder1@gmail.com,founder2@gmail.com
